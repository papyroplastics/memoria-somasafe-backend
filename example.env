# Copy this file to .env and adjust as needed.

# --- Postgres (used by compose.yaml and DATABASE_URL below) ---
POSTGRES_USER=somasafe
POSTGRES_PASSWORD=somasafe
POSTGRES_DB=somasafe

# --- MinIO (used by compose.yaml and the S3_* vars below) ---
MINIO_ROOT_USER=somasafe
MINIO_ROOT_PASSWORD=somasafe

# --- common/config.py ---
S3_ENDPOINT_URL=localhost:9000
S3_ACCESS_KEY=somasafe
S3_SECRET_KEY=somasafe
S3_BUCKET=somasafe
S3_SECURE=false

DATABASE_URL=postgresql+psycopg://somasafe:somasafe@localhost:5432/somasafe
REDIS_URL=redis://localhost:6379/0

SEED_USER=somasafe
SEED_PASSWORD=somasafe
